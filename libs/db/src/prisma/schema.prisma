// npx prisma generate --schema=libs/db/src/prisma/schema.prisma
// npx prisma db push --schema=libs/db/src/prisma/schema.prisma
// $env:DATABASE_URL="mongodb://localhost:27018/db_project?replicaSet=rs0&directConnection=true"; npx prisma db push --schema=libs/db/src/prisma/schema.prisma (run with power shell)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Account {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  email String @unique
  name String
  password String

  messages Message[]

  @@map("accounts")
}

model AuthToken {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  accountId String @db.ObjectId
  refresh_token String

  @@index([accountId,refresh_token])
  @@map("authtokens")
}

model TelegramUser {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  telegramID String @unique
  username String ?
  firstName String
  lastName String ?
  avatarUrl String ?

  // relation
  conversation Conversation?

  @@map("telegramusers")
}

model WelcomeMessage {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  singleton String @unique @default("default")
  value String

  @@map("welcomemessage")
}

model Conversation {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId @unique
  status ConversationStatus @default(OPEN)
  isReadByAdmin Boolean @default(false)
  lastMessageId String? @db.ObjectId @unique
  lastMessageAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  // relation
  messages Message[] @relation("ConversationMessages")
  telegramUser TelegramUser @relation(fields: [userId],references: [id])
  lastMessage Message? @relation("ConversationLastMessage",fields: [lastMessageId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("conversations")
}

model Message {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  fileUrls String[]
  content String?
  type MessageType @default(TEXT)
  senderType SenderType
  sentByAdmin String? @db.ObjectId
  conversationId String @db.ObjectId
  createdAt DateTime @default(now())

  // relation
  account      Account?      @relation(fields: [sentByAdmin], references: [id])
  conversation Conversation @relation("ConversationMessages",fields: [conversationId],references: [id])
  lastMessageOf Conversation? @relation("ConversationLastMessage")

  @@map("messages")
}

enum ConversationStatus {
  OPEN @map("open")
  CLOSED @map("closed")
}

enum MessageType {
  TEXT @map("text")
  FILE @map("file")
}

enum SenderType {
  INCOMING @map("incoming")
  OUTGOING @map("outgoing")
}
